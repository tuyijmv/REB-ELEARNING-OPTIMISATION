# Moodle Environment Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# DATABASE CONFIGURATION (MySQL 8.4)
# =============================================================================
# Choose your database type: mysql
DB_TYPE=mysql
DB_HOST=mysql
DB_PORT=3306

# Database credentials
DB_NAME=moodle
DB_USER=moodleuser
DB_PASSWORD=moodlepass
DB_ROOT_PASSWORD=rootpass

# Database table prefix
DB_PREFIX=mdl_

# =============================================================================
# MOODLE CONFIGURATION
# =============================================================================
# Moodle site URL components
MOODLE_PROTOCOL=http
MOODLE_HOST=localhost
MOODLE_PORT=80

# Alternatively, set MOODLE_WWWROOT directly (overrides the above)
# MOODLE_WWWROOT=http://localhost:8080

# Moodle settings
MOODLE_DEBUG=false
MOODLE_MAIL_NOREPLY=noreply@example.com
MOODLE_MAIL_PREFIX=[Moodle]
MOODLE_REVERSEPROXY=false
MOODLE_SSLPROXY=false

# =============================================================================
# MINIO S3 STORAGE CONFIGURATION
# =============================================================================
# MinIO credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# MinIO ports
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# MinIO region and bucket
MINIO_REGION=us-east-1
MINIO_BUCKET=moodle

# S3 configuration for Moodle
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=moodle
S3_REGION=us-east-1

# =============================================================================
# TO SWITCH TO POSTGRESQL (if you add it to docker-compose.yml):
# =============================================================================
# Uncomment these lines and comment out the MariaDB settings above:
# DB_TYPE=pgsql
# DB_HOST=postgres
# DB_PORT=5432
